# MongoDB connection string
MONGODB_URI=mongodb+srv://admin:admin@myatlasclusteredu.opxelwq.mongodb.net/modeEvents

# NextAuth secret — run: openssl rand -base64 32
NEXTAUTH_SECRET=your-super-secret-key-here

# Base URL of your deployment
NEXTAUTH_URL=http://localhost:3000

# Resend email service
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=hello@yourdomain.com

# Admin panel access — comma-separate for multiple admins
ADMIN_EMAIL=admin@yourdomain.com
NEXT_PUBLIC_ADMIN_EMAIL=admin@yourdomain.com
